# ─── FastFoodie Production Environment ────────────────────
# Copy to .env and fill in your values:
#   cp .env.example .env && nano .env

# Database
DATABASE_URL="file:./dev.db"

# JWT Secret — MUST change this!
# Generate: openssl rand -base64 48
JWT_SECRET="CHANGE-ME"
JWT_EXPIRES_IN="8h"

# Session
SESSION_EXPIRES_HOURS=4

# Server
HOST="0.0.0.0"
PORT=3000
NODE_ENV="production"

# CORS — your actual domains (comma-separated)
# Example: https://admin.myrestaurant.com,https://order.myrestaurant.com
CORS_ORIGINS="https://admin.example.com,https://order.example.com"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW="1 minute"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
